APP_IMAGE=mooping/app-data-center:latest
APP_PORT=3000
APP_URL=http://localhost:3000
SERVER_ACTION_ALLOWED_ORIGINS=localhost:3000,127.0.0.1:3000

# External MariaDB/MySQL connection. The database is not started by Docker Compose.
# URL-encode password characters such as @, #, /, ?, and :.
DATABASE_URL=mysql://app_user:app_password_change_me@db-host:3306/app_data_center

JWT_SECRET=change-this-to-a-long-random-secret-before-production
TOTP_ISSUER=App Data Center
TZ=Asia/Bangkok
