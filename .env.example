APP_IMAGE=mooping/app-data-center:latest
APP_PORT=3000
APP_URL=http://localhost:3000
SERVER_ACTION_ALLOWED_ORIGINS=localhost:3000,127.0.0.1:3000

MARIADB_IMAGE=mooping/app-data-center-db:latest
MARIADB_DATABASE=app_data_center
MARIADB_USER=app_user
MARIADB_PASSWORD=app_password_change_me
MARIADB_ROOT_PASSWORD=root_password_change_me
DB_PORT=3306
DB_DATA_PATH=./data/mariadb
# Optional. Leave empty/commented to let docker-compose.yml build it from the MariaDB vars above.
# Set this manually only when the DB password contains URL-special characters or you use an external DB.
# DATABASE_URL=mysql://app_user:app_password_change_me@db:3306/app_data_center

JWT_SECRET=change-this-to-a-long-random-secret-before-production
TOTP_ISSUER=App Data Center
TZ=Asia/Bangkok
